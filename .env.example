# ═══════════════════════════════════════════════════════════════
# PeakPack — Environment Variables
#
# FOR COOLIFY DEPLOYMENT: set these in Coolify UI → Environment Variables
# DO NOT commit a filled .env file — secrets must never be in source code.
# Generate secrets with: openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────
# Coolify: copy from PostgreSQL resource "Connection String"
DATABASE_URL=postgresql://peakpack:STRONG_PASSWORD@HOST:5432/peakpack

# ── Redis ─────────────────────────────────────────────────────
# Coolify: copy from Redis resource "Connection String"
REDIS_URL=redis://HOST:6379

# ── Auth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://yourdomain.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
JWT_ACCESS_SECRET=generate_with_openssl_rand_base64_32
JWT_REFRESH_SECRET=generate_with_openssl_rand_base64_32
BCRYPT_ROUNDS=12

# ── MinIO ─────────────────────────────────────────────────────
# Coolify: copy from MinIO resource connection details
# MINIO_ENDPOINT is the internal Docker hostname (not the public domain)
MINIO_ENDPOINT=your-minio-internal-hostname
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_PHOTOS=progress-photos
# Public URL where browsers can load images (MinIO subdomain in Coolify)
MINIO_PUBLIC_URL=https://media.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="PeakPack <noreply@yourdomain.com>"

# ── Socket.IO / CORS ──────────────────────────────────────────
# Must match your frontend domain EXACTLY (no trailing slash)
SOCKET_CORS_ORIGIN=https://yourdomain.com

# ── Frontend public vars (baked into Next.js at build time) ───
# Coolify (separate subdomains):
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com
