# ═══════════════════════════════════════════════════════════════
# PeakPack — Environment Variables
#
# FOR COOLIFY DEPLOYMENT: set these in Coolify UI → Environment Variables
# DO NOT commit a filled .env file — secrets must never be in source code.
# ═══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://yourdomain.com

# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── Database ──────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
# Use the "Transaction pooler" connection string for best performance
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────────────
# Coolify: copy from Redis resource "Connection String"
REDIS_URL=redis://HOST:6379

# ── MinIO ─────────────────────────────────────────────────────
# Coolify: copy from MinIO resource connection details
# MINIO_ENDPOINT is the internal Docker hostname (not the public domain)
MINIO_ENDPOINT=your-minio-internal-hostname
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_PHOTOS=progress-photos
# Public URL where browsers can load images (MinIO subdomain in Coolify)
MINIO_PUBLIC_URL=https://media.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="PeakPack <noreply@yourdomain.com>"

# ── Socket.IO / CORS ──────────────────────────────────────────
# Must match your frontend domain EXACTLY (no trailing slash)
SOCKET_CORS_ORIGIN=https://yourdomain.com

# ── Frontend public vars (baked into Next.js at build time) ───
# Coolify (separate subdomains):
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com
